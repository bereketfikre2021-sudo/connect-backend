generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model HeroSlide {
  id              String   @id @default(uuid())
  backgroundImage String   @map("background_image")
  imagePublicId   String?  @map("image_public_id")
  headline        String?
  subheadline     String?
  buttonText      String?  @map("button_text")
  buttonUrl       String?  @map("button_url")
  altText         String?  @map("alt_text")
  autoSlideDelay  Int      @default(4000) @map("auto_slide_delay")
  displayOrder    Int      @default(0) @map("display_order")
  published       Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  status          String   @default("active")

  @@map("hero_slides")
}

model PortfolioProject {
  id                 String   @id @default(uuid())
  thumbnail          String
  thumbnailPublicId  String?  @map("thumbnail_public_id")
  gallery            String[] @default([])
  galleryPublicIds   String[] @default([]) @map("gallery_public_ids")
  title              String
  slug               String   @unique
  category           String
  client             String?
  industry           String?
  year               Int?
  shortDescription   String?  @map("short_description")
  fullDescription    String?  @map("full_description")
  servicesProvided   String[] @default([]) @map("services_provided")
  technologies       String[] @default([])
  projectUrl         String?  @map("project_url")
  altText            String?  @map("alt_text")
  caseStudyChallenge String?  @map("case_study_challenge")
  caseStudySolution  String?  @map("case_study_solution")
  caseStudyResults   Json?    @map("case_study_results")
  featured           Boolean  @default(false)
  published          Boolean  @default(true)
  displayOrder       Int      @default(0) @map("display_order")
  seoTitle           String?  @map("seo_title")
  seoDescription     String?  @map("seo_description")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  status             String   @default("published")

  @@map("portfolio_projects")
}

model CaseStudy {
  id               String   @id @default(uuid())
  heroImage        String   @map("hero_image")
  heroPublicId     String?  @map("hero_public_id")
  gallery          String[] @default([])
  galleryPublicIds String[] @default([]) @map("gallery_public_ids")
  title            String
  slug             String   @unique
  client           String
  industry         String?
  overview         String?
  challenge        String[] @default([])
  research         String?
  strategy         String?
  designProcess    String?  @map("design_process")
  solution         String?
  role             String[] @default([])
  results          String?
  conclusion       String?
  published        Boolean  @default(true)
  displayOrder     Int      @default(0) @map("display_order")
  seoTitle         String?  @map("seo_title")
  seoDescription   String?  @map("seo_description")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("case_studies")
}

model BlogPost {
  id             String    @id @default(uuid())
  featuredImage  String?   @map("featured_image")
  imagePublicId  String?   @map("image_public_id")
  title          String
  slug           String    @unique
  excerpt        String?
  content        String
  category       String?
  tags           String[]  @default([])
  author         String    @default("Connect Digitals")
  readingTime    Int?      @map("reading_time")
  status         String    @default("draft")
  published      Boolean   @default(false)
  publishedAt    DateTime? @map("published_at")
  displayOrder   Int       @default(0) @map("display_order")
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  scheduledAt    DateTime? @map("scheduled_at")

  @@map("blog_posts")
}

model TrustedBrand {
  id           String   @id @default(uuid())
  logo         String
  logoPublicId String?  @map("logo_public_id")
  name         String
  website      String?
  altText      String?  @map("alt_text")
  displayOrder Int      @default(0) @map("display_order")
  published    Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("trusted_brands")
}

model Testimonial {
  id            String   @id @default(uuid())
  clientPhoto   String?  @map("client_photo")
  photoPublicId String?  @map("photo_public_id")
  clientName    String   @map("client_name")
  position      String?
  company       String?
  review        String
  rating        Int      @default(5)
  href          String?
  featured      Boolean  @default(false)
  displayOrder  Int      @default(0) @map("display_order")
  published     Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}

model PageView {
  id       String   @id @default(uuid())
  page     String
  slug     String?
  referrer String?
  country  String?
  viewedAt DateTime @default(now()) @map("viewed_at")

  @@index([page])
  @@index([viewedAt])
  @@map("page_views")
}

model Visitor {
  id          String           @id @default(uuid())
  fingerprint String           @unique
  ip          String?
  country     String?
  city        String?
  device      String?
  browser     String?
  os          String?
  language    String?
  firstSeen   DateTime         @default(now()) @map("first_seen")
  lastSeen    DateTime         @default(now()) @map("last_seen")
  visits      Int              @default(1)
  sessions    Session[]
  events      AnalyticsEvent[]

  @@index([fingerprint])
  @@index([firstSeen])
  @@index([country])
  @@map("visitors")
}

model Session {
  id        String           @id @default(uuid())
  visitorId String           @map("visitor_id")
  visitor   Visitor          @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  referrer  String?
  source    String?
  startedAt DateTime         @default(now()) @map("started_at")
  endedAt   DateTime?        @map("ended_at")
  duration  Int?
  bounced   Boolean          @default(true)
  events    AnalyticsEvent[]

  @@index([visitorId])
  @@index([startedAt])
  @@map("sessions")
}

model AnalyticsEvent {
  id         String    @id @default(uuid())
  visitorId  String?   @map("visitor_id")
  visitor    Visitor?  @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  sessionId  String?   @map("session_id")
  session    Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  type       String
  name       String
  value      String?
  duration   Int?
  scrollPct  Int?      @map("scroll_pct")
  recordedAt DateTime  @default(now()) @map("recorded_at")

  @@index([type])
  @@index([name])
  @@index([recordedAt])
  @@map("analytics_events")
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String   @map("entity_id")
  title     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}

model ContactLead {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  company     String?
  service     String?
  budget      String?
  message     String
  status      String   @default("new")
  notes       String?
  submittedAt DateTime @default(now()) @map("submitted_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("contact_leads")
}

model Setting {
  id               String   @id @default(uuid())
  websiteName      String   @default("Connect Digitals") @map("website_name")
  logo             String?
  logoPublicId     String?  @map("logo_public_id")
  favicon          String?
  faviconPublicId  String?  @map("favicon_public_id")
  seoTitle         String?  @map("seo_title")
  seoDescription   String?  @map("seo_description")
  seoKeywords      String?  @map("seo_keywords")
  socialFacebook   String?  @map("social_facebook")
  socialInstagram  String?  @map("social_instagram")
  socialTwitter    String?  @map("social_twitter")
  socialLinkedin   String?  @map("social_linkedin")
  socialWhatsapp   String?  @map("social_whatsapp")
  contactEmail     String?  @map("contact_email")
  contactPhone     String?  @map("contact_phone")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  slogan           String?
  statExperience   Int      @default(5) @map("stat_experience")
  statProjects     Int      @default(150) @map("stat_projects")
  statSatisfaction Int      @default(98) @map("stat_satisfaction")
  tagline          String?

  @@map("settings")
}
